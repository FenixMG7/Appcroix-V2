rules_version = '2';

// Modèle : un compte Firebase Auth (email/mot de passe) = une famille.
// L'UID Firebase Auth EST l'ID du document families/{familyId}.
// Toutes les sous-collections (members, categories, ...) héritent de la
// même règle : seul le compte propriétaire peut lire/écrire ses données.
// Il n'y a pas de distinction parent/enfant au niveau Firestore : cette
// distinction est gérée côté application (choix de profil + code PIN),
// pas au niveau des règles de sécurité. Voir DEPLOYMENT.md section 5.
service cloud.firestore {
  match /databases/{database}/documents {
    match /families/{familyId} {
      allow read, write: if request.auth != null && request.auth.uid == familyId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == familyId;
      }
    }
  }
}
